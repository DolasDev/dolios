# Copy to .env and edit for your environment.

# LLM endpoint. Points at the Ollama instance on the dolo-llm machine.
# Use whatever your LAN can resolve — hostname, mDNS .local, or raw IP.
# Inside Docker, the hermes container relies on the host's resolver to reach it.
OPENAI_BASE_URL=http://dolo-llm.local:11434/v1
OPENAI_API_KEY=ollama

# Model tag served by Ollama. Must match an entry in infra/ollama/models.txt.
MODEL_NAME=qwen2.5:7b-instruct-q5_K_M

# Postgres
POSTGRES_PASSWORD=changeme

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
