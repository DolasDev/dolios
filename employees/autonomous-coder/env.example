# autonomous-coder secrets — copy to the profile's .env, fill in, keep private.
# Materialized to ~/.hermes/profiles/autonomous-coder/.env (git-ignored there;
# this example template is the only thing tracked).

# Needed for the OpenRouter fallback in config.yaml (model.fallback_providers).
# Without it, the agent runs fine on the local model but cannot fail over.
# Get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# The local model needs no key. Claude Code dispatch uses the host's existing
# ~/.claude credentials (the usage gate reads them), not a key here.
