# autonomous-coder secrets — copy to the profile's .env, fill in, keep private.
# Materialized to ~/.hermes/profiles/autonomous-coder/.env (git-ignored there;
# this example template is the only thing tracked).

# The local model needs no key. Claude Code dispatch uses the mounted ~/.claude
# credentials (the usage gate reads them), not a key here. There is intentionally
# no OPENROUTER_API_KEY: fleet policy is $0 marginal API spend, so the supervisor
# does NOT fail over to OpenRouter — it halts cleanly if dolo-llm is unreachable.

# Needed for the PR path when running containerized: the container has no host
# `gh` auth to inherit, so the dispatcher authenticates gh via this token.
# Use a fine-grained PAT with contents + pull_requests write on the allowlisted
# repos. https://github.com/settings/tokens
# GH_TOKEN=ghp_...

# Root of the allowlisted repo checkouts on THIS HOST. `coder.yaml`'s allowlist
# uses ${REPOS_ROOT}/<repo>, so the same file works on host AND in the container
# without per-environment paths in the allowlist itself.
#
# The container's compose service overrides this with /opt/data/repos via its
# `environment:` block (docker compose `environment:` takes precedence over
# `env_file:`), so this line ONLY affects host-side runs (e.g.
# `set -a && . .env && set +a && python3 services/coder/tick.py`).
REPOS_ROOT=/home/steve/repos
