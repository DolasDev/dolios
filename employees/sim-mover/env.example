# sim-mover secrets — copy to the profile's .env, fill in, keep private.
# Materialized to ~/.hermes/profiles/sim-mover/.env.

# Pegasus API bearer key — used server-side by the Pegasus MCP server (Phase 4),
# never exposed to the model. Not needed until that server exists.
# PEGASUS_API_KEY=...

# Only if this employee ever routes through OpenRouter:
# OPENROUTER_API_KEY=sk-or-...
