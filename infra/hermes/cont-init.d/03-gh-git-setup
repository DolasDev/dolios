#!/command/with-contenv sh
# Wire git so the autonomous coder can push from inside the container without
# SSH keys. Two pieces:
#
#   1. `gh auth setup-git` writes a credential.https.github.com.helper line
#      into the hermes user's ~/.gitconfig that delegates HTTPS auth to gh,
#      which uses GH_TOKEN (passed in via env_file from the profile .env).
#
#   2. `url.https://github.com/.insteadOf git@github.com:` rewrites the
#      dolios remote's SSH URL (git@github.com:DolasDev/dolios.git) to its
#      HTTPS equivalent at git op time. Without this, git push tries SSH,
#      the container has no SSH keys, host-key verification fails.
#
# Both land in /opt/data/.gitconfig (the hermes user's $HOME = /opt/data),
# which is on the bind-mounted host ~/.hermes, so the config survives
# container restarts.
#
# Notes:
#   - Shebang is `#!/command/with-contenv sh`, NOT `#!/bin/sh` — s6-overlay
#     sanitizes PID 1's env down to PATH only; with-contenv re-injects the
#     docker env (GH_TOKEN among them).
#   - `HOME=/opt/data` is required when going through `s6-setuidgid hermes` —
#     s6-setuidgid sets uid/gid but does NOT change HOME, so gh and git would
#     otherwise read/write at /root/.config/... and /root/.gitconfig.

if [ -z "${GH_TOKEN:-}" ]; then
    echo "[gh-git-setup] GH_TOKEN not set — skipping (autonomous push will fail until it is)"
    exit 0
fi

HOME=/opt/data s6-setuidgid hermes sh -c '
    set -e
    gh auth setup-git
    git config --global url."https://github.com/".insteadOf "git@github.com:"
' && echo "[gh-git-setup] credential helper + SSH→HTTPS rewrite installed for hermes" \
  || echo "[gh-git-setup] setup failed (autonomous push will fail until fixed)"
